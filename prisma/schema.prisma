generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  CREATOR
  ADMIN
}
enum LinkStatus {
  LIVE
  REVIEW
  BLOCKED
}
enum LedgerType {
  AD_REVENUE
  PREMIUM_POOL
  AFFILIATE
  ADJUSTMENT
  PAYOUT
}
enum PayoutStatus {
  REQUESTED
  APPROVED
  SCHEDULED
  PAID
  HELD
  REJECTED
}
enum AdPayoutType {
  CPM
  CPC
  FLAT
  AFFILIATE
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  passwordHash   String?
  role           Role            @default(USER)
  premiumUntil   DateTime?
  referralCode   String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  profile        CreatorProfile?
  links          Link[]
  clicks         Click[]
  ledgerEntries  LedgerEntry[]
  payoutAccounts PayoutAccount[]
  supportTickets SupportTicket[]
  apiKeys        ApiKey[]
}

model CreatorProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  handle     String   @unique
  bio        String?
  website    String?
  fraudScore Int      @default(0)
  payoutHold Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Link {
  id             String         @id @default(cuid())
  creatorId      String
  slug           String         @unique
  title          String
  destinationUrl String
  status         LinkStatus     @default(REVIEW)
  premiumBoost   Boolean        @default(true)
  apiCreated     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  creator        User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  clicks         Click[]
  adImpressions  AdImpression[]

  @@index([creatorId, createdAt])
  @@index([status, createdAt])
}

model Click {
  id           String   @id @default(cuid())
  linkId       String
  visitorId    String?
  userId       String?
  ipHash       String?
  userAgent    String?
  country      String?
  riskScore    Int      @default(0)
  qualified    Boolean  @default(false)
  premium      Boolean  @default(false)
  revenueCents Int      @default(0)
  createdAt    DateTime @default(now())
  link         Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id])

  @@index([linkId, createdAt])
  @@index([visitorId, createdAt])
  @@index([qualified, createdAt])
}

model LedgerEntry {
  id          String     @id @default(cuid())
  userId      String
  type        LedgerType
  amountCents Int
  note        String?
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model PayoutAccount {
  id         String   @id @default(cuid())
  userId     String
  provider   String
  externalId String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payouts    Payout[]

  @@index([userId, provider])
}

model Payout {
  id              String        @id @default(cuid())
  payoutAccountId String
  amountCents     Int
  status          PayoutStatus  @default(REQUESTED)
  paypalBatchId   String?
  paypalItemId    String?
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  account         PayoutAccount @relation(fields: [payoutAccountId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([payoutAccountId, createdAt])
}

model AffiliateReferral {
  id             String   @id @default(cuid())
  referrerUserId String
  referredUserId String
  commissionBps  Int      @default(1000)
  createdAt      DateTime @default(now())

  @@index([referrerUserId, createdAt])
  @@index([referredUserId, createdAt])
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  subject   String
  body      String
  status    String   @default("open")
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SponsorCampaign {
  id              String         @id @default(cuid())
  sponsorName     String
  title           String
  description     String
  targetUrl       String
  placement       String
  payoutType      AdPayoutType
  budgetCents     Int
  spentCents      Int            @default(0)
  creatorShareBps Int            @default(5000)
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  impressions     AdImpression[]

  @@index([active, placement])
  @@index([createdAt])
}

model AdImpression {
  id           String          @id @default(cuid())
  campaignId   String
  linkId       String?
  visitorId    String?
  clicked      Boolean         @default(false)
  qualified    Boolean         @default(false)
  revenueCents Int             @default(0)
  createdAt    DateTime        @default(now())
  campaign     SponsorCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  link         Link?           @relation(fields: [linkId], references: [id])

  @@index([campaignId, createdAt])
  @@index([linkId, createdAt])
  @@index([clicked, createdAt])
  @@index([qualified, createdAt])
}