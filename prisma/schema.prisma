generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  CREATOR
  ADMIN
}

enum LinkStatus {
  LIVE
  REVIEW
  BLOCKED
}

enum LedgerType {
  AD_REVENUE
  PREMIUM_POOL
  AFFILIATE
  ADJUSTMENT
  PAYOUT
}

enum PayoutStatus {
  REQUESTED
  SCHEDULED
  PAID
  HELD
  REJECTED
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  passwordHash   String?
  role           Role            @default(USER)
  premiumUntil   DateTime?
  referralCode   String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  profile        CreatorProfile?
  links          Link[]
  clicks         Click[]
  ledgerEntries  LedgerEntry[]
  payoutAccounts PayoutAccount[]
  supportTickets SupportTicket[]
}

model CreatorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  handle      String   @unique
  bio         String?
  website     String?
  fraudScore  Int      @default(0)
  payoutHold  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Link {
  id             String     @id @default(cuid())
  creatorId      String
  slug           String     @unique
  title          String
  destinationUrl String
  status         LinkStatus @default(REVIEW)
  premiumBoost   Boolean    @default(true)
  apiCreated     Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  creator        User       @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  clicks         Click[]
}

model Click {
  id          String   @id @default(cuid())
  linkId      String
  visitorId   String?
  userId      String?
  ipHash      String?
  userAgent   String?
  country     String?
  riskScore   Int      @default(0)
  qualified   Boolean  @default(false)
  premium     Boolean  @default(false)
  revenueCents Int     @default(0)
  createdAt   DateTime @default(now())
  link        Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
}

model LedgerEntry {
  id          String     @id @default(cuid())
  userId      String
  type        LedgerType
  amountCents Int
  note        String?
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PayoutAccount {
  id         String   @id @default(cuid())
  userId     String
  provider   String
  externalId String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payouts    Payout[]
}

model Payout {
  id              String       @id @default(cuid())
  payoutAccountId String
  amountCents     Int
  status          PayoutStatus @default(REQUESTED)
  reviewedAt      DateTime?
  createdAt       DateTime     @default(now())
  account         PayoutAccount @relation(fields: [payoutAccountId], references: [id], onDelete: Cascade)
}

model AffiliateReferral {
  id             String   @id @default(cuid())
  referrerUserId String
  referredUserId String
  commissionBps  Int      @default(1000)
  createdAt      DateTime @default(now())
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  subject   String
  body      String
  status    String   @default("open")
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  keyHash     String   @unique
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
}
